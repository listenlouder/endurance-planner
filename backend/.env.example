# Django secret key — generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to True only in development, never in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames (e.g. localhost,127.0.0.1,myapp.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# MariaDB / MySQL database name
DB_NAME=endurance_planner

# Database user with full privileges on DB_NAME
DB_USER=endurance_user

# Password for DB_USER
DB_PASSWORD=

# Database host (usually localhost for local dev)
DB_HOST=localhost

# Database port (MariaDB/MySQL default is 3306)
DB_PORT=3306

# Static files root — used by collectstatic in production
# STATIC_ROOT is set automatically in settings.py (BASE_DIR/staticfiles)

# Password to access the feedback viewer at /feedback/view/
FEEDBACK_PASSWORD=choose-a-strong-password
